    "type": "git",
    "url": "git+https://github.com/JBHi-Fi/node-printer.git"
  },
  "scripts": {
    "install": "node-gyp-build",
    "typecheck": "tsc --pretty false --noEmit --skipLibCheck --module commonjs --moduleResolution node --target es2018 --esModuleInterop --types ./index.d.ts,node examples-ts/*.ts examples-ts/types/*.d.ts"
